# Copy this file to `.env` and fill it in.  NEVER commit `.env`.
#
#   cp .env.example .env
#   nano .env

# Cloudflare Tunnel token. Create a tunnel in the Cloudflare Zero Trust dashboard
# (Networks -> Tunnels -> Create -> Docker) and paste the token here. In the same
# place, add a Public Hostname:  api.yourdomain.com  ->  http://app:3000
TUNNEL_TOKEN=paste-your-cloudflare-tunnel-token-here

# Website origin(s) allowed to POST RSVPs (your live wedding site).
# Comma-separate if you have more than one. NO trailing slash, NO path.
ALLOWED_ORIGIN=https://mk-meden.github.io

# Secret that gates the dashboard and the list/stats endpoints.
# Use a long random value. Generate one with:  openssl rand -hex 24
ADMIN_TOKEN=change-me-to-a-long-random-secret
