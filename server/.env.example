# Copy to `.env` for LOCAL runs. On Render, set these in the dashboard
# (Environment tab) instead — never commit real secrets.

# Postgres connection string. From Neon: Dashboard -> your project -> Connection
# string (choose "Pooled"). It looks like:
#   postgresql://user:pass@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Website origin(s) allowed to POST RSVPs (your live wedding site).
# Comma-separate for multiple. NO trailing slash, NO path.
ALLOWED_ORIGIN=https://mk-meden.github.io

# Secret that gates the dashboard and the list/stats endpoints.
# Use a long random value:  openssl rand -hex 24
ADMIN_TOKEN=change-me-to-a-long-random-secret

# Optional for local runs (Render sets PORT automatically).
# PORT=3000
